# Offline RL datasets (each source HDF5 is ~105 MB, exceeds GitHub's 100 MB
# per-file limit and the 1 GB recommended repo size). Host these separately
# (e.g. Zenodo deposit) and document the download in each
# subproject's README.
Hopper_Gravity/data/sources_replay/*.hdf5
Hopper_Gravity/data/*.hdf5

# Python cache / build artifacts
__pycache__/
*.pyc
*.pyo

# Editor / OS detritus
.DS_Store
Thumbs.db
*~
*.swp

# Run-time leftovers (regenerable from sweeps)
*.log.bak
results/em_master.log
results/iql_master.log
